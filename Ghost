-- Combined Touch Fling + Anti Fling + Godmode + Super Ring GUI
-- Made for Roblox (FE compatible where possible)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local hrp = character:WaitForChild("HumanoidRootPart")

-- Variables
local touchFlingEnabled = false
local antiFlingEnabled = false
local godmodeEnabled = false
local superRingEnabled = false
local ringRadius = 20
local ringParts = {}

-- Create GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FlingGodRingGUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 300, 0, 400)
mainFrame.Position = UDim2.new(0.5, -150, 0.5, -200)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

-- Make draggable
local dragging = false
local dragInput
local dragStart
local startPos

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 50)
title.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
title.Text = "Touch Fling + Godmode + Ring GUI"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.SourceSansBold
title.TextSize = 18
title.Parent = mainFrame

-- Touch Fling Toggle
local btnTouch = Instance.new("TextButton")
btnTouch.Size = UDim2.new(0.9, 0, 0, 40)
btnTouch.Position = UDim2.new(0.05, 0, 0, 60)
btnTouch.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
btnTouch.Text = "Touch Fling: OFF"
btnTouch.TextColor3 = Color3.new(1,1,1)
btnTouch.Font = Enum.Font.SourceSansBold
btnTouch.TextSize = 16
btnTouch.Parent = mainFrame

btnTouch.MouseButton1Click:Connect(function()
    touchFlingEnabled = not touchFlingEnabled
    btnTouch.Text = "Touch Fling: " .. (touchFlingEnabled and "ON" or "OFF")
    btnTouch.BackgroundColor3 = touchFlingEnabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
end)

-- Touch Fling Logic
character.Touched:Connect(function(part)
    if not touchFlingEnabled then return end
    local otherChar = part.Parent
    if otherChar and otherChar:FindFirstChild("Humanoid") and otherChar \~= character then
        local otherHrp = otherChar:FindFirstChild("HumanoidRootPart")
        if otherHrp then
            otherHrp.Velocity = hrp.CFrame.LookVector * 500 + Vector3.new(0, 100, 0) -- Strong fling upward/forward
        end
    end
end)

-- Anti Fling Toggle
local btnAnti = Instance.new("TextButton")
btnAnti.Size = UDim2.new(0.9, 0, 0, 40)
btnAnti.Position = UDim2.new(0.05, 0, 0, 110)
btnAnti.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
btnAnti.Text = "Anti Fling: OFF"
btnAnti.TextColor3 = Color3.new(1,1,1)
btnAnti.Font = Enum.Font.SourceSansBold
btnAnti.TextSize = 16
btnAnti.Parent = mainFrame

btnAnti.MouseButton1Click:Connect(function()
    antiFlingEnabled = not antiFlingEnabled
    btnAnti.Text = "Anti Fling: " .. (antiFlingEnabled and "ON" or "OFF")
    btnAnti.BackgroundColor3 = antiFlingEnabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
end)

-- Anti Fling Loop
RunService.Heartbeat:Connect(function()
    if antiFlingEnabled and hrp then
        -- Limit crazy velocities/rotations
        if hrp.Velocity.Magnitude > 200 then
            hrp.Velocity = hrp.Velocity.Unit * 150
        end
        if hrp.RotVelocity.Magnitude > 50 then
            hrp.RotVelocity = Vector3.new(0,0,0)
        end
    end
end)

-- Godmode Toggle
local btnGod = Instance.new("TextButton")
btnGod.Size = UDim2.new(0.9, 0, 0, 40)
btnGod.Position = UDim2.new(0.05, 0, 0, 160)
btnGod.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
btnGod.Text = "Godmode: OFF"
btnGod.TextColor3 = Color3.new(1,1,1)
btnGod.Font = Enum.Font.SourceSansBold
btnGod.TextSize = 16
btnGod.Parent = mainFrame

btnGod.MouseButton1Click:Connect(function()
    godmodeEnabled = not godmodeEnabled
    btnGod.Text = "Godmode: " .. (godmodeEnabled and "ON" or "OFF")
    btnGod.BackgroundColor3 = godmodeEnabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
