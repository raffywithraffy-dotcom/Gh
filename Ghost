-- Godmode Loop
RunService.Heartbeat:Connect(function()
    if godmodeEnabled and humanoid then
        humanoid.Health = humanoid.MaxHealth
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    end
end)

-- Super Ring Toggle + Radius Slider (simple TextBox)
local btnRing = Instance.new("TextButton")
btnRing.Size = UDim2.new(0.9, 0, 0, 40)
btnRing.Position = UDim2.new(0.05, 0, 0, 210)
btnRing.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
btnRing.Text = "Super Ring: OFF"
btnRing.TextColor3 = Color3.new(1,1,1)
btnRing.Font = Enum.Font.SourceSansBold
btnRing.TextSize = 16
btnRing.Parent = mainFrame

local radiusLabel = Instance.new("TextLabel")
radiusLabel.Size = UDim2.new(0.4, 0, 0, 30)
radiusLabel.Position = UDim2.new(0.05, 0, 0, 260)
radiusLabel.BackgroundTransparency = 1
radiusLabel.Text = "Radius:"
radiusLabel.TextColor3 = Color3.new(1,1,1)
radiusLabel.Font = Enum.Font.SourceSans
radiusLabel.TextSize = 16
radiusLabel.Parent = mainFrame

local radiusBox = Instance.new("TextBox")
radiusBox.Size = UDim2.new(0.5, 0, 0, 30)
radiusBox.Position = UDim2.new(0.45, 0, 0, 260)
radiusBox.BackgroundColor3 = Color3.fromRGB(50,50,50)
radiusBox.Text = tostring(ringRadius)
radiusBox.TextColor3 = Color3.new(1,1,1)
radiusBox.Font = Enum.Font.SourceSans
radiusBox.TextSize = 16
radiusBox.Parent = mainFrame

radiusBox.FocusLost:Connect(function()
    local num = tonumber(radiusBox.Text)
    if num then ringRadius = math.clamp(num, 5, 100) end
    radiusBox.Text = tostring(ringRadius)
end)

btnRing.MouseButton1Click:Connect(function()
    superRingEnabled = not superRingEnabled
    btnRing.Text = "Super Ring: " .. (superRingEnabled and "ON" or "OFF")
    btnRing.BackgroundColor3 = superRingEnabled and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
    
    if not superRingEnabled then
        for _, p in ipairs(ringParts) do p:Destroy() end
        ringParts = {}
    end
end)

-- Super Ring Loop
RunService.Heartbeat:Connect(function()
    if not superRingEnabled or not hrp then return end
    
    -- Clear old parts if needed
    if #ringParts == 0 then
        for i = 1, 36 do
            local part = Instance.new("Part")
            part.Size = Vector3.new(4, 4, 4)
            part.Shape = Enum.PartType.Ball
            part.Anchored = true
            part.CanCollide = false
            part.Transparency = 0.7
            part.Color = Color3.fromRGB(255, 0, 100)
            part.Parent = workspace
            table.insert(ringParts, part)
        end
    end
    
    local angleStep = (math.pi * 2) / #ringParts
    for i, part in ipairs(ringParts) do
        local angle = (tick() * 5) + (i * angleStep)  -- spinning effect
        local offset = Vector3.new(math.cos(angle) * ringRadius, 5, math.sin(angle) * ringRadius)
        part.CFrame = hrp.CFrame * CFrame.new(offset)
        
        -- Fling anything touching the ring
        for _, obj in ipairs(workspace:GetPartBoundsInRadius(part.Position, 6)) do
            if obj \~= part and obj \~= hrp and obj.CanCollide then
                local vel = (obj.Position - hrp.Position).Unit * 300 + Vector3.new(0, 150, 0)
                if obj:FindFirstChild("HumanoidRootPart") then
                    obj.HumanoidRootPart.Velocity = vel
                elseif obj.Velocity then
                    obj.Velocity = vel
                end
            end
        end
    end
end)

-- Close button
local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 30, 0, 30)
closeBtn.Position = UDim2.new(1, -35, 0, 5)
closeBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
closeBtn.Text = "X"
closeBtn.TextColor3 = Color3.new(1,1,1)
closeBtn.Font = Enum.Font.SourceSansBold
closeBtn.TextSize = 20
closeBtn.Parent = mainFrame

closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

print("Fling + Godmode + Super Ring GUI loaded! Drag the window to move it.")
