    local buttons = {
        {"Decal Spam (raffy style)", function()
            local decalId = "rbxassetid://8408806737"  
            for _, part in pairs(Workspace:GetDescendants()) do
                if part:IsA("BasePart") then
                    for i = 1, 6 do
                        local decal = Instance.new("Decal")
                        decal.Texture = decalId
                        decal.Face = i-1
                        decal.Parent = part
                    end
