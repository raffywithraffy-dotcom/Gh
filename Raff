contentFrame.Position = UDim2.new(0, 0, 0, 75)
contentFrame.BackgroundTransparency = 1
contentFrame.Parent = mainFrame

-- Simple Tab System
local function createButton(text, parent, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.3, 0, 1, 0)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    btn.BorderColor3 = Color3.fromRGB(180, 0, 255)
    btn.BorderSizePixel = 2
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(200, 0, 255)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextScaled = true
    btn.Parent = parent
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- Tab Buttons
local localBtn = createButton("Local Trolls", tabFrame, function() loadLocalTab() end)
local serverBtn = createButton("Server Chaos", tabFrame, function() loadServerTab() end)
local chaosBtn = createButton("Extra Chaos", tabFrame, function() loadChaosTab() end)

-- Clear content
local function clearContent()
    for _, child in pairs(contentFrame:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then
            child:Destroy()
        end
    end
end

-- Local Trolls Tab
function loadLocalTab()
    clearContent()
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.Parent = contentFrame

    local buttons = {
        {"Fly (Toggle - Press E)", function() 
            local flying = false
            local bv = Instance.new("BodyVelocity")
            local bg = Instance.new("BodyGyro")
            local char = LocalPlayer.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            
            game:GetService("UserInputService").InputBegan:Connect(function(input)
                if input.KeyCode == Enum.KeyCode.E then
                    flying = not flying
                    if flying then
                        bv.Parent = root
                        bg.Parent = root
                        bv.MaxForce = Vector3.new(4000,4000,4000)
                        bg.MaxTorque = Vector3.new(4000,4000,4000)
                        print("raffy FLY ON")
                    else
                        bv:Destroy()
                        bg:Destroy()
                        print("raffy FLY OFF")
                    end
                end
            end)
            print("Press E to toggle raffy Fly")
        end},
        {"Infinite Jump", function()
            LocalPlayer.Character.Humanoid.JumpPower = 100
            game:GetService("UserInputService").JumpRequest:Connect(function()
                LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end)
            print("raffy Infinite Jump ON")
        end},
        {"Speed Boost (100)", function()
            local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum.WalkSpeed = 100 end
            print("raffy Speed = 100")
        end},
        {"Invisible (Client)", function()
            local char = LocalPlayer.Character
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name \~= "HumanoidRootPart" then
                        part.Transparency = 1
                    end
                end
            end
            print("raffy Invisible mode ON")
        end},
        {"Rainbow Character", function()
            spawn(function()
                while wait(0.1) do
                    local char = LocalPlayer.Character
                    if char then
                        for _, part in pairs(char:GetChildren()) do
                            if part:IsA("BasePart") then
                                part.Color = Color3.fromHSV(tick() % 5 / 5, 1, 1)
                            end
                        end
                    end
                end
            end)
            print("raffy Rainbow mode activated")
        end}
    }

    for i, btnData in ipairs(buttons) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.9, 0, 0, 50)
        btn.Position = UDim2.new(0.05, 0, 0, (i-1) * 60)
        btn.BackgroundColor3 = Color3.fromRGB(15, 15, 25)
        btn.BorderColor3 = Color3.fromRGB(180, 0, 255)
        btn.Text = btnData[1]
        btn.TextColor3 = Color3.fromRGB(255, 255, 100)
        btn.Font = Enum.Font.SourceSansBold
        btn.TextScaled = true
        btn.Parent = frame
        btn.MouseButton1Click:Connect(btnData[2])
    end
end

-- Server Chaos Tab
